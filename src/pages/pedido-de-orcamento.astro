---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWhatsAppHref, contactConfig, whatsappMessages } from '../data/siteConfig';

const title = 'Pedido de orçamento para projeto digital';
const description = 'Prepara um pedido claro para serviços de blog, conteúdo, páginas e recursos digitais.';
const whatsappBaseUrl = `https://wa.me/${contactConfig.whatsappNumber}`;
const quoteWhatsappHref = buildWhatsAppHref(whatsappMessages.quote);
---

<BaseLayout title={title} description={description}>
  <main class="quote-page">
    <section class="hero">
      <p class="eyebrow">Pedido de orçamento</p>
      <h1>Organiza o teu pedido antes de entrar em contacto</h1>
      <p>Preenche os campos abaixo para preparar uma mensagem clara. O formulário não envia dados automaticamente: no fim, podes copiar o resumo ou abrir o WhatsApp com o pedido organizado.</p>
    </section>

    <section class="layout">
      <form id="quote-form" class="quote-form">
        <div class="field-grid">
          <label>Nome<input id="name" type="text" placeholder="O teu nome" required /></label>
          <label>Contacto de retorno<input id="contact" type="text" placeholder="WhatsApp ou outro contacto que prefiras" required /></label>
        </div>
        <label>Tipo de apoio
          <select id="service" required>
            <option value="">Seleciona uma opção</option>
            <option>Mini Diagnóstico de Site</option>
            <option>Página Comercial Essencial</option>
            <option>Blog ou Site Inicial Organizado</option>
            <option>Outro projeto digital</option>
          </select>
        </label>
        <label>Objetivo principal<textarea id="objective" rows="4" placeholder="Explica o que queres criar, melhorar ou organizar" required></textarea></label>
        <div class="field-grid">
          <label>Faixa de orçamento<select id="budget"><option>Ainda não definido</option><option>Quero começar pequeno</option><option>Tenho orçamento definido</option><option>Prefiro receber proposta por etapas</option></select></label>
          <label>Prazo desejado<select id="timeline"><option>Sem urgência</option><option>Esta semana</option><option>Nas próximas 2 semanas</option><option>Ainda estou a planear</option></select></label>
        </div>
        <label>Contexto adicional<textarea id="details" rows="5" placeholder="Links, público, recursos já existentes ou outras informações úteis"></textarea></label>
        <div class="form-actions">
          <button type="submit">Preparar pedido</button>
          <a
            href={quoteWhatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir WhatsApp com modelo simples de pedido de orçamento"
            data-analytics-event="whatsapp_click"
            data-analytics-category="commercial"
            data-analytics-label="pedido modelo vazio"
          >
            Abrir WhatsApp sem preencher
          </a>
        </div>
      </form>

      <aside class="side-card">
        <h2>Como funciona</h2>
        <ol><li>Preenche o resumo do projeto.</li><li>Gera uma mensagem organizada.</li><li>Revê o texto preparado.</li><li>Abre o WhatsApp para continuar a conversa.</li></ol>
        <p>O orçamento final depende do objetivo, escopo, prazo, materiais disponíveis e nível de apoio necessário.</p>
      </aside>
    </section>

    <section id="result-section" class="result" hidden>
      <p class="eyebrow">Pedido preparado</p>
      <h2>Revê e copia esta mensagem</h2>
      <textarea id="request-output" rows="14" readonly></textarea>
      <div class="form-actions">
        <button id="copy-request" type="button">Copiar pedido</button>
        <a
          id="open-whatsapp-request"
          href={quoteWhatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Abrir WhatsApp com pedido de orçamento preparado"
          data-analytics-event="whatsapp_click"
          data-analytics-category="commercial"
          data-analytics-label="pedido de orcamento"
        >
          Abrir WhatsApp com pedido
        </a>
      </div>
      <p id="copy-status" class="status" aria-live="polite"></p>
    </section>
  </main>

  <script define:vars={{ whatsappBaseUrl }}>
    const form = document.querySelector('#quote-form');
    const resultSection = document.querySelector('#result-section');
    const output = document.querySelector('#request-output');
    const copyButton = document.querySelector('#copy-request');
    const whatsappLink = document.querySelector('#open-whatsapp-request');
    const copyStatus = document.querySelector('#copy-status');
    const value = (id) => document.querySelector(`#${id}`)?.value?.trim() || 'Não informado';
    const buildWhatsappLink = (message) => `${whatsappBaseUrl}?text=${encodeURIComponent(message)}`;

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      output.value = [
        'Olá, Equipa Dinheiro na Net. Gostaria de pedir um orçamento.', '',
        `Objetivo: ${value('objective')}`,
        `Tipo de ajuda: ${value('service')}`,
        `Prazo: ${value('timeline')}`,
        `Contexto ou link: ${value('details')}`, '',
        `Nome: ${value('name')}`,
        `Contacto de retorno: ${value('contact')}`,
        `Faixa de orçamento: ${value('budget')}`
      ].join('\n');
      if (whatsappLink) whatsappLink.href = buildWhatsappLink(output.value);
      resultSection.hidden = false;
      resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      copyStatus.textContent = 'Pedido preparado. Revê o texto e abre o WhatsApp para continuar.';
    });

    copyButton?.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(output.value); }
      catch { output.select(); document.execCommand('copy'); }
      copyStatus.textContent = 'Pedido copiado. Agora abre o WhatsApp e cola o texto se precisares ajustar antes de enviar.';
    });
  </script>

  <style>
    .quote-page { max-width: 1120px; margin: 0 auto; padding: 3rem 1rem; }
    .hero { padding: 2rem; border-radius: 28px; color: white; background: linear-gradient(135deg, #0f172a, #1d4ed8); }
    .eyebrow { margin: 0; font-size: .82rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: #bbf7d0; }
    .hero h1 { margin: .55rem 0 1rem; color: white; font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.06; }
    .hero p { max-width: 780px; color: white; font-size: 1.06rem; }
    .layout { display: grid; grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr); gap: 1rem; margin-top: 1.5rem; }
    .quote-form, .side-card, .result { padding: 1.4rem; border: 1px solid rgba(148,163,184,.3); border-radius: 22px; background: white; box-shadow: 0 14px 32px rgba(15,23,42,.06); }
    .quote-form label { display: grid; gap: .45rem; margin-bottom: 1rem; font-weight: 750; }
    .quote-form input, .quote-form textarea, .quote-form select, .result textarea { width: 100%; box-sizing: border-box; border: 1px solid #cbd5e1; border-radius: 12px; padding: .75rem; font: inherit; background: #fff; }
    .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .9rem; }
    .form-actions { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; margin-top: .35rem; }
    .form-actions button, .form-actions a { border: 0; border-radius: 999px; padding: .78rem 1.05rem; text-decoration: none; font: inherit; font-weight: 800; cursor: pointer; background: #0f172a; color: white; }
    .form-actions a { background: #e2e8f0; color: #0f172a; }
    .side-card h2, .result h2 { margin-top: 0; }
    .side-card li { margin: .65rem 0; }
    .result { margin-top: 1rem; }
    .status { margin-bottom: 0; color: #166534; font-weight: 700; }
    @media (max-width: 800px) { .layout, .field-grid { grid-template-columns: 1fr; } .hero { padding: 1.3rem; } }
  </style>
</BaseLayout>
