---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página Não Encontrada" description="A página que tentou aceder já não existe ou foi movida.">
  <div class="container text-center pt-section pb-section error-page">
    <h1 class="error-code">404</h1>
    <h2>Oops! Página Não Encontrada</h2>
    <p class="error-desc">Parece que estavas à procura de uma página que já não existe, mas foca-te em encontrar caminhos para renda digital, que nós tratamos de apagar os becos sem saída do site.</p>
    
    <div class="action-btn">
      <a href="/" class="btn-primary">Voltar ao Início</a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    text-align: center;
    padding: 6rem 0;
  }
  
  .error-code {
    font-size: 8rem;
    font-weight: 800;
    color: var(--color-primary-light);
    margin: 0;
    line-height: 1;
  }
  
  .error-desc {
    max-width: 600px;
    margin: 1.5rem auto;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }
  
  .action-btn {
    margin-top: 2rem;
  }
</style>
