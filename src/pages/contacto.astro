---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCommercialPaths from '../components/ContactCommercialPaths.astro';
import ContactExpectations from '../components/ContactExpectations.astro';
import { buildWhatsAppHref, contactConfig, whatsappMessages } from '../data/siteConfig';

const generalWhatsappHref = buildWhatsAppHref(whatsappMessages.general);
---

<BaseLayout 
  title="Contacto | Dinheiro na Net"
  description="Entre em contacto com a equipa do Dinheiro na Net para questões, sugestões ou colaborações."
>
  <div class="container--narrow" style="padding: 3rem 1.25rem 5rem">
    <h1>Contacto</h1>
    <p class="lead">Tens uma questão, sugestão de tema ou queres colaborar? Entra em contacto connosco.</p>

    <div class="contact-options">
      <div class="contact-card">
        <div class="contact-icon" aria-hidden="true">WhatsApp</div>
        <h2>Fala com a {contactConfig.publicName}</h2>
        <p>Para dúvidas gerais, sugestões de artigos, pedidos de orientação ou colaboração, usa o WhatsApp público do projeto.</p>
        <a
          href={generalWhatsappHref}
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Abrir WhatsApp da ${contactConfig.publicName}`}
          data-analytics-event="whatsapp_click"
          data-analytics-category="commercial"
          data-analytics-label="contacto geral"
        >
          WhatsApp {contactConfig.whatsappDisplay}
        </a>
        <p class="contact-note">Nesta fase não há e-mail público profissional. O WhatsApp é o canal funcional para contacto direto.</p>
      </div>
    </div>

    <div class="contact-note-box">
      <h3>O que não fazemos</h3>
      <ul>
        <li>Não fornecemos aconselhamento financeiro</li>
        <li>Não prometemos resultados de monetização</li>
        <li>Não vendemos cursos prontos nem pacotes sem análise prévia</li>
        <li>Não compramos links ou aceitamos guest posts pagos na fase atual</li>
      </ul>
    </div>
  </div>

<!-- contacto-comercial-v1-paths -->
<ContactCommercialPaths />
<ContactExpectations />
</BaseLayout>

<style>
  .lead { font-size: 1.15rem; color: var(--color-text-muted); margin-bottom: 2rem; }
  .contact-options { margin: 2rem 0; }
  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
  }
  .contact-icon {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .contact-card h2 { margin-top: 0; }
  .contact-card .btn {
    max-width: 100%;
    white-space: normal;
    overflow-wrap: anywhere;
    text-align: center;
  }
  .contact-note { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 1rem; margin-bottom: 0; }
  .contact-note-box {
    background: var(--color-surface-2);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    margin-top: 2.5rem;
  }
  .contact-note-box h3 { margin-top: 0; }
  .contact-note-box ul { color: var(--color-text-muted); }
</style>
