---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { categories } from '../../data/siteConfig';
---

<BaseLayout title="Categorias | Dinheiro na Net" description="Explore todos os tópicos sobre criação de renda e negócios digitais.">
  <div class="container">
    <div class="page-header">
      <h1>Categorias</h1>
      <p>Navega pelos temas centrais e encontra o guia que melhor serve as tuas necessidades.</p>
    </div>
    <div class="categories-grid">
      {categories.map((cat) => (
        <CategoryCard name={cat.name} slug={cat.slug} description={cat.description} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    max-width: 700px;
    margin: 2rem auto 4rem;
  }
  .page-header p { font-size: 1.2rem; color: var(--color-text-muted); }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 1.5rem;
    padding-bottom: 4rem;
  }
</style>
