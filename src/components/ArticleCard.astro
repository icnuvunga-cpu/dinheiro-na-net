---
import { formatDate } from '../utils/posts';

interface Props {
  title: string;
  url: string;
  description: string;
  date: string;
  category: string;
}

const { title, url, description, date, category } = Astro.props;
---

<article class="article-card">
  <a href={url} class="card-inner" tabindex="-1" aria-hidden="true"></a>
  <div class="card-body">
    <div class="card-meta">
      <span class="badge badge--category">{category}</span>
      <time datetime={date} class="card-date">{formatDate(date)}</time>
    </div>
    <h3 class="card-title">
      <a href={url}>{title}</a>
    </h3>
    <p class="card-excerpt">{description}</p>
  </div>
  <div class="card-footer">
    <a href={url} class="card-cta" aria-label={`Ler artigo: ${title}`}>
      Ler artigo <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>

<style>
  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
    position: relative;
  }

  .article-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--color-primary-light);
  }

  /* invisible full-card link for hover state (not in tab order) */
  .card-inner {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card-body {
    padding: 1.4rem 1.4rem 0.75rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }

  .badge--category {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    background-color: var(--color-primary);
    color: white;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    line-height: 1.3;
  }

  .card-title a {
    color: var(--color-primary);
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .card-title a:hover { color: var(--color-primary-light); text-decoration: underline; }

  .card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    /* 3-line clamp */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    padding: 0.75rem 1.4rem 1.2rem;
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
    position: relative;
    z-index: 1;
  }

  .card-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary-light);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: gap 0.15s ease, color 0.15s ease;
  }

  .card-cta:hover {
    color: var(--color-primary);
    gap: 0.5rem;
    text-decoration: none;
  }
</style>
